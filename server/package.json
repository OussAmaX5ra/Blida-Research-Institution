{
  "name": "research-lab-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API for the Blida Research Institute platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "check-env": "node src/config/check-env.js",
    "create-admin": "node src/scripts/create-admin-user.js",
    "dev": "node --watch src/server.js",
    "seed-content": "node src/scripts/seed-content.js",
    "seed-content:minimal": "node src/scripts/seed-content.js --file=./seed-data/content.minimal.json --replace",
    "seed-content:full": "node src/scripts/seed-content.js --file=./seed-data/content.full-ui-demo.json --replace",
    "build:full-ui-demo-seed": "node src/scripts/build-full-ui-demo-seed.mjs",
    "export-content": "node src/scripts/export-content.js",
    "start": "node src/server.js",
    "verify:content": "node src/scripts/verify-content-integrity.js",
    "verify:milestone1": "node src/scripts/verify-milestone-1.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.18.0",
    "zod": "^3.25.76"
  }
}
